# ContextLens Environment Configuration
# Copy this to .env and fill in your real API keys

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# --- NVIDIA NIM (optional) ---
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=meta/llama-3.1-70b-instruct

# --- ContextLens Settings ---
CONTEXTLENS_LOG_DIR=./logs
CONTEXTLENS_MAX_CONTEXT_TOKENS=8000
CONTEXTLENS_DEFAULT_PROVIDER=groq
CONTEXTLENS_ENABLE_OPTIMIZATION=true
```

